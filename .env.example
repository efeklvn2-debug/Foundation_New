# Server Configuration
PORT=3001
NODE_ENV=development

# Database (if using a database)
# DATABASE_URL=postgresql://username:password@localhost:5432/emerhana_foundation
# DATABASE_SSL=false

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@emerhana-foundation.org

# Contact Email
CONTACT_EMAIL=info@emerhana-foundation.org

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://emerhana-foundation.org

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
VITE_HOTJAR_ID=YOUR_HOTJAR_ID
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# CMS Configuration (Optional)
VITE_CMS_API_URL=https://your-cms-api.com
VITE_CMS_API_KEY=your-cms-api-key

# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# Security (generate random strings)
VITE_CSRF_SECRET=your-random-csrf-secret-here
JWT_SECRET=your-jwt-secret-here

# Payment Gateway (Optional - for online donations)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLIC_KEY=pk_test_xxx
# PAYSTACK_SECRET_KEY=sk_test_xxx